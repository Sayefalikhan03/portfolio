---
// Endpoint is wired in Phase 2 (Cloudflare Worker). Until PUBLIC_ASKAI_ENDPOINT is set,
// the widget shows a graceful placeholder instead of calling a non-existent backend.
const endpoint = import.meta.env.PUBLIC_ASKAI_ENDPOINT ?? '';
const starters = [
  'What is Sayef good at?',
  'Does he have an engineering background?',
  'Is he open to relocation?',
  'Tell me about his AI projects.',
];
---

<section id="ask-ai" class="askai">
  <div class="container">
    <div class="askai__panel" data-endpoint={endpoint}>
      <div class="askai__head">
        <span class="askai__dot" aria-hidden="true"></span>
        <h2>Ask my AI</h2>
      </div>
      <p class="askai__sub">
        Curious whether I'm a fit? Ask my assistant anything about my experience, skills, or
        availability — it answers from my real CV and projects, any time of day.
      </p>

      <div class="askai__chips" role="list">
        {starters.map((s) => <button class="askai__chip" type="button" role="listitem">{s}</button>)}
      </div>

      <div class="askai__log" id="askai-log" aria-live="polite"></div>

      <form class="askai__inputrow" id="askai-form">
        <input
          class="askai__input"
          id="askai-input"
          type="text"
          name="q"
          placeholder="Ask anything about Sayef…"
          autocomplete="off"
          aria-label="Ask my AI a question"
        />
        <button class="btn" type="submit">Ask</button>
      </form>

      <p class="askai__note">
        Powered by Claude behind a rate-limited <code>Cloudflare Worker</code>. Answers are scoped to my
        professional background.
      </p>
    </div>
  </div>
</section>

<script>
  const panel = document.querySelector<HTMLElement>('.askai__panel');
  const form = document.getElementById('askai-form') as HTMLFormElement | null;
  const input = document.getElementById('askai-input') as HTMLInputElement | null;
  const log = document.getElementById('askai-log') as HTMLElement | null;

  if (panel && form && input && log) {
    const endpoint = panel.dataset.endpoint || '';

    const append = (text: string, who: 'user' | 'bot') => {
      const el = document.createElement('div');
      el.className = `askai__msg askai__msg--${who}`;
      el.textContent = text;
      log.appendChild(el);
      log.classList.add('has-messages');
      log.scrollTop = log.scrollHeight;
      return el;
    };

    const ask = async (question: string) => {
      const q = question.trim();
      if (!q) return;
      append(q, 'user');
      input.value = '';

      if (!endpoint) {
        append(
          "The live assistant is being wired up right now. In the meantime, reach me directly at khan.sayef03@gmail.com or via the contact form below — happy to answer anything.",
          'bot'
        );
        return;
      }

      const pending = append('Thinking…', 'bot');
      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question: q }),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        pending.textContent = data.answer ?? 'Sorry, I could not generate an answer just now.';
      } catch {
        pending.textContent =
          'Something went wrong reaching the assistant. Please try again, or email khan.sayef03@gmail.com.';
      }
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      ask(input.value);
    });

    document.querySelectorAll<HTMLButtonElement>('.askai__chip').forEach((chip) => {
      chip.addEventListener('click', () => ask(chip.textContent || ''));
    });
  }
</script>
