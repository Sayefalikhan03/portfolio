---
import { type Lang, defaultLang } from '../i18n';

interface Props {
  lang?: Lang;
}
const { lang = defaultLang } = Astro.props;

// Existing Formspree endpoint — works on static hosting.
const formAction = 'https://formspree.io/f/mqkvgjvw';

const content = {
  en: {
    heading: 'Contact',
    sub: 'Based in the Nuremberg–Erlangen area, Germany. Open to new opportunities.',
    intro: 'Have a question or want to work together? Send a message through the form or reach out directly.',
    name: 'Name',
    email: 'Email',
    message: 'Message',
    send: 'Send message',
  },
  de: {
    heading: 'Kontakt',
    sub: 'Ansässig im Raum Nürnberg–Erlangen, Deutschland. Offen für neue Möglichkeiten.',
    intro: 'Eine Frage oder Interesse an einer Zusammenarbeit? Schreiben Sie mir über das Formular oder direkt.',
    name: 'Name',
    email: 'E-Mail',
    message: 'Nachricht',
    send: 'Nachricht senden',
  },
};
const t = content[lang];
---

<section id="contact" class="section">
  <div class="container">
    <header class="section__header reveal">
      <h2>{t.heading}</h2>
      <p>{t.sub}</p>
    </header>

    <div class="contact-grid">
      <div class="contact-info reveal">
        <p>{t.intro}</p>
        <div class="contact-links">
          <a href="mailto:khan.sayef03@gmail.com">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            khan.sayef03@gmail.com
          </a>
          <a href="tel:+4917636190070">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            (+49) 176 3619 0070
          </a>
        </div>
        <div class="contact-social">
          <a href="https://www.linkedin.com/in/sayef-ali-khan/" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com/Sayefalikhan03" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
        </div>
      </div>

      <form class="contact-form reveal" method="post" action={formAction}>
        <div class="form-row">
          <label>
            <span>{t.name}</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label>
            <span>{t.email}</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>
        </div>
        <label>
          <span>{t.message}</span>
          <textarea name="message" rows="5" required></textarea>
        </label>
        <button type="submit" class="btn">{t.send}</button>
      </form>
    </div>
  </div>
</section>
