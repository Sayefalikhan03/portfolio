---
// Levels confirmed with Sayef (Jun 2026). B1 certificate remains in the Certs section;
// current spoken German is business fluent.
const langs = [
  { name: 'English', level: 'Fluent', pct: '92%' },
  { name: 'German', level: 'Business fluent', pct: '88%' },
  { name: 'Bangla', level: 'Native', pct: '100%' },
  { name: 'Hindi', level: 'Native / Bilingual', pct: '100%' },
];
---

<section id="languages" class="section">
  <div class="container">
    <header class="section__header reveal">
      <h2>Languages</h2>
      <p>Comfortable working in multilingual teams and with international stakeholders.</p>
    </header>

    <div class="lang-grid reveal">
      {langs.map((l) => (
        <div class="lang-item">
          <div class="lang-label">
            <span>{l.name}</span>
            <span>{l.level}</span>
          </div>
          <div class="lang-bar">
            <div class="lang-bar__fill" style={`--level: ${l.pct}`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
