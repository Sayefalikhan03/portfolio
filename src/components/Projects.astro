---
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

const statusLabel: Record<string, string> = {
  live: 'Live',
  'in-progress': 'In progress',
  research: 'Research',
};
---

<section id="projects" class="section">
  <div class="container">
    <header class="section__header reveal">
      <h2>Projects &amp; work in progress</h2>
      <p>Real systems, practical learning. Case studies are added as they mature.</p>
    </header>

    <div class="grid cards">
      {projects.map((p) => {
        const d = p.data;
        const hasImage = Boolean(d.image);
        const classes = ['card', 'reveal'];
        if (d.featured) classes.push('card--featured');
        if (!hasImage) classes.push('card--no-image');
        return (
          <article class={classes.join(' ')}>
            {hasImage && (
              <figure class="card__media">
                <img
                  src={`${base}/images/${d.image}`}
                  alt={d.imageAlt ?? d.title}
                  width="1200"
                  height="675"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}
            <div class="card__body">
              <div class="card__head">
                <h3>{d.title}</h3>
                <div class="card__head-right">
                  <span class={`status status--${d.status}`}>{statusLabel[d.status]}</span>
                  <svg class="card__arrow" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 17L17 7M17 7H8M17 7V16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              </div>
              <p>{d.summary}</p>
              {(d.repo || d.link) && (
                <div class="card__links">
                  {d.repo && (
                    <a href={d.repo} target="_blank" rel="noopener">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                      Code
                    </a>
                  )}
                  {d.link && (
                    <a href={d.link} target="_blank" rel="noopener">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3m-2 16H5V5h7V3H5c-1.11 0-2 .9-2 2v14a2 2 0 002 2h14c1.1 0 2-.9 2-2v-7h-2z"/></svg>
                      Live
                    </a>
                  )}
                </div>
              )}
              <ul class="tags">
                {d.tags.map((t) => <li>{t}</li>)}
              </ul>
            </div>
          </article>
        );
      })}
    </div>

    <p class="muted small" style="margin-top: 1.5rem;">More projects are added here as they're ready.</p>
  </div>
</section>
